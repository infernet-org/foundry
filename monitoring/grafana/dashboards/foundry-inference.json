   "gridPos": {
    "h": 6,
    "w": 4,
    "x": 0,
    "y": 14
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "nvidia_smi_utilization_gpu_ratio * 100",
     "legendFormat": "{{gpu}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "min": 0,
     "max": 100,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "blue",
        "value": null
       },
       {
        "color": "green",
        "value": 30
       },
       {
        "color": "yellow",
        "value": 80
       },
       {
        "color": "red",
        "value": 95
       }
      ]
     }
    }
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "type": "gauge",
   "title": "VRAM Usage",
   "gridPos": {
    "h": 6,
    "w": 4,
    "x": 4,
    "y": 14
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "nvidia_smi_memory_used_bytes / nvidia_smi_memory_total_bytes * 100",
     "legendFormat": "{{gpu}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "min": 0,
     "max": 100,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 80
       },
       {
        "color": "red",
        "value": 95
       }
      ]
     }
    }
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "type": "stat",
   "title": "GPU Temperature",
   "gridPos": {
    "h": 3,
    "w": 4,
    "x": 8,
    "y": 14
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "nvidia_smi_temperature_gpu",
     "legendFormat": "{{gpu}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "celsius",
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "blue",
        "value": null
       },
       {
        "color": "green",
        "value": 40
       },
       {
        "color": "yellow",
        "value": 70
       },
       {
        "color": "red",
        "value": 85
       }
      ]
     }
    }
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "background"
   }
  },
  {
   "type": "stat",
   "title": "GPU Power Draw",
   "gridPos": {
    "h": 3,
    "w": 4,
    "x": 8,
    "y": 17
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "nvidia_smi_power_draw_watts",
     "legendFormat": "{{gpu}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "watt",
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 300
       },
       {
        "color": "orange",
        "value": 450
       },
       {
        "color": "red",
        "value": 550
       }
      ]
     }
    }
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "background"
   }
  },
  {
   "type": "timeseries",
   "title": "GPU Utilization & Memory BW Over Time",
   "gridPos": {
    "h": 6,
    "w": 12,
    "x": 12,
    "y": 14
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "nvidia_smi_utilization_gpu_ratio * 100",
     "legendFormat": "GPU Compute %"
    },
    {
     "expr": "nvidia_smi_utilization_memory_ratio * 100",
     "legendFormat": "Memory BW %"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "min": 0,
     "max": 100,
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "smooth",
      "fillOpacity": 15
     }
    }
   }
  },
  {
   "type": "timeseries",
   "title": "VRAM Usage Over Time",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 0,
    "y": 20
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "nvidia_smi_memory_used_bytes / 1073741824",
     "legendFormat": "Used (GB)"
    },
    {
     "expr": "nvidia_smi_memory_total_bytes / 1073741824",
     "legendFormat": "Total (GB)"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "decgbytes",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 10
     }
    }
   }
  },
  {
   "type": "timeseries",
   "title": "GPU Temperature & Power",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 6,
    "y": 20
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "nvidia_smi_temperature_gpu",
     "legendFormat": "Temperature (C)"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "celsius",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 10
     }
    }
   }
  },
  {
   "type": "timeseries",
   "title": "GPU Clock Speeds",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 12,
    "y": 20
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "nvidia_smi_clocks_current_graphics_clock_hz / 1000000",
     "legendFormat": "Graphics (MHz)"
    },
    {
     "expr": "nvidia_smi_clocks_current_memory_clock_hz / 1000000",
     "legendFormat": "Memory (MHz)"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "MHz",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 10
     }
    }
   }
  },
  {
   "type": "stat",
   "title": "GPU Fan Speed",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 18,
    "y": 20
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "nvidia_smi_fan_speed_ratio * 100",
     "legendFormat": "{{gpu}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
