{
 "uid": "foundry-inference",
 "title": "Foundry Inference (vLLM)",
 "description": "vLLM inference telemetry: throughput, MTP speculative decoding, latency percentiles, KV cache, GPU.",
 "tags": [
  "foundry",
  "llm",
  "inference",
  "gpu"
 ],
 "timezone": "browser",
 "editable": true,
 "fiscalYearStartMonth": 0,
 "graphTooltip": 1,
 "refresh": "15s",
 "schemaVersion": 39,
 "templating": {
  "list": []
 },
 "time": {
  "from": "now-1h",
  "to": "now"
 },
 "panels": [
  {
   "type": "row",
   "title": "Inference",
   "gridPos": {
    "h": 1,
    "w": 24,
    "x": 0,
    "y": 0
   },
   "collapsed": false
  },
  {
   "type": "gauge",
   "title": "Decode Speed (tok/s)",
   "description": "Current token generation throughput",
   "gridPos": {
    "h": 6,
    "w": 4,
    "x": 0,
    "y": 1
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "rate(vllm:generation_tokens_total[1m])",
     "refId": "A"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "tok/s",
     "min": 0,
     "max": 400,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "orange",
        "value": 50
       },
       {
        "color": "yellow",
        "value": 100
       },
       {
        "color": "green",
        "value": 150
       }
      ]
     },
     "color": {
      "mode": "thresholds"
     }
    }
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "showThresholdLabels": false,
    "showThresholdMarkers": true
   }
  },
  {
   "type": "gauge",
   "title": "Prefill Speed (tok/s)",
   "description": "Current prompt processing throughput",
   "gridPos": {
    "h": 6,
    "w": 4,
    "x": 4,
    "y": 1
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "rate(vllm:prompt_tokens_total[1m])",
     "refId": "A"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "tok/s",
     "min": 0,
     "max": 2000,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "orange",
        "value": 200
       },
       {
        "color": "yellow",
        "value": 500
       },
       {
        "color": "green",
        "value": 800
       }
      ]
     },
     "color": {
      "mode": "thresholds"
     }
    }
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "showThresholdLabels": false,
    "showThresholdMarkers": true
   }
  },
  {
   "type": "stat",
   "title": "Running Requests",
   "description": "Inference slots currently processing requests",
   "gridPos": {
    "h": 3,
    "w": 4,
    "x": 8,
    "y": 1
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "vllm:num_requests_running",
     "refId": "A"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "blue",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       },
       {
        "color": "yellow",
        "value": 3
       },
       {
        "color": "red",
        "value": 4
       }
      ]
     },
     "color": {
      "mode": "thresholds"
     }
    }
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "background",
    "graphMode": "none"
   }
  },
  {
   "type": "stat",
   "title": "Waiting Requests",
   "description": "Requests waiting in queue (all slots busy)",
   "gridPos": {
    "h": 3,
    "w": 4,
    "x": 8,
    "y": 4
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "vllm:num_requests_waiting",
     "refId": "A"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 1
       },
       {
        "color": "red",
        "value": 5
       }
      ]
     },
     "color": {
      "mode": "thresholds"
     }
    }
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "background",
    "graphMode": "none"
   }
  },
  {
   "type": "timeseries",
   "title": "Token Throughput Over Time",
   "description": "Decode and prompt processing throughput",
   "gridPos": {
    "h": 6,
    "w": 12,
    "x": 12,
    "y": 1
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "rate(vllm:generation_tokens_total[1m])",
     "refId": "A",
     "legendFormat": "decode tok/s"
    },
    {
     "expr": "rate(vllm:prompt_tokens_total[1m])",
     "refId": "B",
     "legendFormat": "prefill tok/s"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "tok/s",
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "smooth",
      "fillOpacity": 15,
      "pointSize": 5,
      "showPoints": "auto",
      "spanNulls": true
     }
    }
   },
   "options": {
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    },
    "legend": {
     "displayMode": "list",
     "placement": "bottom"
    }
   }
  },
  {
   "type": "timeseries",
   "title": "Latency Percentiles",
   "description": "Cumulative token counts",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 0,
    "y": 7
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "histogram_quantile(0.5, rate(vllm:time_to_first_token_seconds_bucket[5m]))",
     "refId": "A",
     "legendFormat": "TTFT p50"
    },
    {
     "expr": "histogram_quantile(0.95, rate(vllm:time_to_first_token_seconds_bucket[5m]))",
     "refId": "B",
     "legendFormat": "TTFT p95"
    },
    {
     "expr": "histogram_quantile(0.5, rate(vllm:inter_token_latency_seconds_bucket[5m]))",
     "refId": "C",
     "legendFormat": "inter-token p50"
    },
    {
     "expr": "histogram_quantile(0.95, rate(vllm:inter_token_latency_seconds_bucket[5m]))",
     "refId": "D",
     "legendFormat": "inter-token p95"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "smooth",
      "fillOpacity": 10
     },
     "unit": "s"
    }
   }
  },
  {
   "type": "timeseries",
   "title": "Requests & Preemptions",
   "description": "Average busy slots per decode call and active requests over time",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 6,
    "y": 7
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "vllm:num_requests_running",
     "refId": "A",
     "legendFormat": "running"
    },
    {
     "expr": "vllm:num_requests_waiting",
     "refId": "B",
     "legendFormat": "waiting"
    },
    {
     "expr": "rate(vllm:num_preemptions_total[5m])",
     "refId": "C",
     "legendFormat": "preemptions/s"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "stepAfter",
      "fillOpacity": 20
     }
    }
   }
  },
  {
   "type": "timeseries",
   "title": "MTP Draft Acceptance",
   "description": "Fraction of MTP-drafted tokens accepted by the target model. Workload-dependent: code accepts higher than prose.",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 12,
    "y": 7
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "rate(vllm:spec_decode_num_accepted_tokens_total[5m]) / rate(vllm:spec_decode_num_draft_tokens_total[5m])",
     "legendFormat": "acceptance rate",
     "refId": "A"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "percentunit",
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "smooth",
      "fillOpacity": 15
     },
     "max": 1,
     "min": 0
    }
   }
  },
  {
   "type": "stat",
   "title": "KV Cache Usage",
   "description": "Fraction of GPU KV cache in use. Sustained >95% precedes preemptions.",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 18,
    "y": 7
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "vllm:kv_cache_usage_perc",
     "refId": "A"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "percentunit",
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 0.8
       },
       {
        "color": "red",
        "value": 0.95
       }
      ]
     },
     "color": {
      "mode": "thresholds"
     },
     "max": 1,
     "min": 0
    }
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value",
    "graphMode": "area"
   }
  },
  {
   "type": "row",
   "title": "GPU",
   "gridPos": {
    "h": 1,
    "w": 24,
    "x": 0,
    "y": 13
   },
   "collapsed": false
  },
  {
